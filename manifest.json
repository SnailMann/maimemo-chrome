{
  "manifest_version": 3,
  "name": "墨墨背单词",
  "short_name": "墨墨",
  "description": "maimemo-chrome：右键添加单词到当前云词本，并高亮当前云词本中的单词。",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "https://open.maimemo.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "墨墨背单词设置"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
